{
  "name": "@molten-ai/mypos-connect-sdk",
  "version": "0.1.0",
  "description": "Unofficial server-first TypeScript SDK for the MyPOS Connect API",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Molten-Bot/mypos-connect-sdk.git"
  },
  "homepage": "https://github.com/Molten-Bot/mypos-connect-sdk#readme",
  "bugs": {
    "url": "https://github.com/Molten-Bot/mypos-connect-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "tsup",
    "generate": "openapi-ts",
    "generate:check": "pnpm run generate && git diff --exit-code -- src/generated",
    "lint:openapi": "redocly lint openapi.yaml --lint-config=error",
    "package:check": "publint",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run validate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run lint:openapi && pnpm run generate:check && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run package:check"
  },
  "keywords": [
    "mypos",
    "mypos-connect",
    "sdk",
    "typescript",
    "api-client"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@redocly/cli": "2.39.0",
    "@types/node": "24.10.1",
    "publint": "0.3.21",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}

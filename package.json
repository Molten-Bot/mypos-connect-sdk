{
  "name": "@molten-ai/mypos-connect-contract",
  "version": "0.0.0",
  "private": true,
  "description": "Source contract and validation tooling for the MyPOS Connect SDK",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "docs:typecheck": "node scripts/check-readme-snippets.mjs",
    "lint:openapi": "redocly lint openapi.yaml --lint-config=error",
    "test": "node --test tests/**/*.test.mjs",
    "validate": "pnpm run lint:openapi && pnpm run test && pnpm run docs:typecheck"
  },
  "devDependencies": {
    "@redocly/cli": "2.39.0",
    "typescript": "7.0.2",
    "yaml": "2.9.0"
  }
}

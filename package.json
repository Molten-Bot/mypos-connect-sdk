{
  "name": "@molten-ai/mypos-connect-sdk",
  "version": "0.0.1",
  "description": "Source contract and validation tooling for the MyPOS Connect SDK",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Molten-Bot/mypos-connect-sdk.git"
  },
  "homepage": "https://github.com/Molten-Bot/mypos-connect-sdk#readme",
  "bugs": {
    "url": "https://github.com/Molten-Bot/mypos-connect-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "docs:typecheck": "node scripts/check-readme-snippets.mjs",
    "lint:openapi": "redocly lint openapi.yaml --lint-config=error",
    "test": "node --test tests/**/*.test.mjs",
    "validate": "pnpm run lint:openapi && pnpm run test && pnpm run docs:typecheck"
  },
  "devDependencies": {
    "@redocly/cli": "2.39.0",
    "typescript": "7.0.2",
    "yaml": "2.9.0"
  }
}
